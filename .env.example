# ============================================================
# Webhook Receiver — Environment Variables
# DO NOT commit the resulting .env. Run ./install.sh to generate it,
# or copy this file to .env and fill in real values.
# ============================================================

# Strong random password for admin panel.
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 24
ADMIN_SECRET=__REPLACE_WITH_STRONG_RANDOM__

# Public domain that CPA networks will POST webhooks to (Traefik routes by Host).
WEBHOOK_DOMAIN=webhook.example.com

# Path to the .env file with SMTP_* variables (shared with the WordPress site).
# Optional — if the file does not exist, worker runs without email notifications.
SMTP_ENV_FILE=/path/to/site/.env

# Timezone (service runs in UTC; storage and logs are UTC).
TZ=UTC
